<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ApexRouter-CLI Cron Daemon — launchd user agent (macOS)

  Installation:
    1. Copy this file to ~/Library/LaunchAgents/com.apexrouter.cron-daemon.plist
    2. Edit the paths below to match your installation:
         - ProgramArguments: path to the apexrouter-cli binary
         - APEXROUTER_CLI_HOME: your ApexRouter home directory (default ~/.apexrouter)
    3. Load the agent:
         launchctl bootstrap gui/$(id -u) \
           ~/Library/LaunchAgents/com.apexrouter.cron-daemon.plist
    4. Verify it is running:
         launchctl list com.apexrouter.cron-daemon

  Uninstall:
    launchctl bootout gui/$(id -u) \
      ~/Library/LaunchAgents/com.apexrouter.cron-daemon.plist

  Notes:
    - The daemon writes its PID to $APEXROUTER_CLI_HOME/cron-daemon.pid
    - Logs go to $APEXROUTER_CLI_HOME/cron-daemon.log (stdout + stderr)
    - launchd restarts the daemon automatically if it crashes
    - To stop temporarily: launchctl kill TERM gui/$(id -u)/com.apexrouter.cron-daemon
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.apexrouter.cron-daemon</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Replace with the absolute path to the apexrouter-cli binary. -->
    <!-- Example: /usr/local/bin/apexrouter-cli                        -->
    <string>/usr/local/bin/apexrouter-cli</string>
    <string>cron</string>
    <string>daemon</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <!-- Override if your ApexRouter home is not ~/.apexrouter -->
    <key>APEXROUTER_CLI_HOME</key>
    <string>~/.apexrouter</string>
    <!-- Prevents the child-process re-exec dance; launchd is already
         the process manager, so we run the daemon body directly. -->
    <key>APEXROUTER_CLI_CRON_DAEMON_CHILD</key>
    <string>1</string>
  </dict>

  <!-- Restart on crash. launchd throttles to at most once per 10 s. -->
  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <!-- Run from the user's home directory. -->
  <key>WorkingDirectory</key>
  <string>~</string>

  <!-- Route stdout + stderr to the daemon log file. -->
  <key>StandardOutPath</key>
  <string>~/.apexrouter/cron-daemon.log</string>
  <key>StandardErrorPath</key>
  <string>~/.apexrouter/cron-daemon.log</string>

  <!-- Launch at login. -->
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
