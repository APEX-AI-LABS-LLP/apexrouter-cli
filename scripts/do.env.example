# ApexRouter-CLI e2e infrastructure — DigitalOcean credentials TEMPLATE
#
# Copy this to ~/.config/apexrouter-e2e/do.env and fill in your values.
# That path is gitignored (and won't be committed).
#
#   mkdir -p ~/.config/apexrouter-e2e
#   chmod 700 ~/.config/apexrouter-e2e
#   cp scripts/do.env.example ~/.config/apexrouter-e2e/do.env
#   chmod 600 ~/.config/apexrouter-e2e/do.env
#   $EDITOR ~/.config/apexrouter-e2e/do.env
#
# Override the env-file location: export APEXROUTER_CLI_E2E_ENV=/some/other/path

# REQUIRED: DigitalOcean API token (recommend least-privilege scope:
#   droplet:read+write, ssh_keys:read, regions:read, images:read+write,
#   snapshots:read. NOT account-wide full-scope — see docs/e2e.md §security)
DIGITALOCEAN_API_TOKEN="dop_v1_PASTE_YOUR_TOKEN_HERE"

# REQUIRED: SSH key registered on the DO account
# (run: curl -H "Authorization: Bearer $DIGITALOCEAN_API_TOKEN" \
#         https://api.digitalocean.com/v2/account/keys | jq '.ssh_keys[]')
DO_SSH_KEY_ID="00000000"                          # numeric id from DO API
DO_SSH_KEY_NAME=""                                # name on DO (informational)
DO_SSH_KEY_FINGERPRINT_SHA256=""                  # from: ssh-keygen -lf <pub> -E sha256
DO_SSH_KEY_FINGERPRINT_MD5=""                     # from: DO API .ssh_keys[].fingerprint
DO_SSH_PRIVATE_KEY_PATH="$HOME/.ssh/do_apexrouter_e2e"  # local path to matching private key

# REQUIRED: GitHub deploy key (read-only) registered on APEX-AI-LABS-LLP/apexrouter-cli
GITHUB_DEPLOY_KEY_PATH="$HOME/.ssh/deploy_apexrouter_cli"
GITHUB_DEPLOY_KEY_FINGERPRINT_SHA256=""           # from: ssh-keygen -lf <pub> -E sha256
GITHUB_DEPLOY_KEY_LABEL="apexrouter-e2e-clone"
GITHUB_REPO="git@github.com:APEX-AI-LABS-LLP/apexrouter-cli.git"

# REQUIRED: which DO region to spin droplets in
DO_REGION="nyc3"                                  # closest to GitHub East Coast + crates.io

# OPTIONAL: account-info (auto-populated by the scripts on first valid run)
# DO_ACCOUNT_EMAIL=""
# DO_TEAM_UUID=""
# DO_TEAM_NAME=""
# DO_DROPLET_LIMIT="10"

# OPTIONAL: hint to the cost-monitoring helper (informational only)
BILLING_ALERT_USD="50"
